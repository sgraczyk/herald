# Telegram
TELEGRAM_TOKEN=your_bot_token

# Chutes.ai (OpenAI-compatible fallback)
CHUTES_API_KEY=your_api_key

# Access control (comma-separated Telegram user IDs)
ALLOWED_USER_IDS=123456789,987654321

# Claude CLI token expiry (shown in /health response)
CLAUDE_TOKEN_EXPIRES=2027-03-05

# Log level override (optional, overrides config.json log_level)
# LOG_LEVEL=debug
