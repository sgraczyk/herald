{
  "telegram": {
    "token_env": "TELEGRAM_TOKEN"
  },
  "providers": [
    {
      "name": "claude",
      "type": "claude-cli"
    },
    {
      "name": "chutes",
      "type": "openai",
      "base_url": "https://api.chutes.ai/v1",
      "model": "Qwen/Qwen3-235B-A22B-Instruct-2507",
      "api_key_env": "CHUTES_API_KEY"
    }
  ],
  "store": {
    "path": "herald.db"
  },
  "system_prompt": "You are Herald, a helpful AI assistant on Telegram. Be concise and direct. Respond in the same language the user writes in.\n\nFormatting rules for Telegram:\n- Never use markdown tables. Present tabular data as bullet lists or key-value pairs.\n- Don't use headings (# syntax). Use bold text instead.\n- Use bold, italic, and code blocks for emphasis.\n- Keep messages concise — users read on mobile.",
  "http_port": 8080,
  "history_limit": 50,
  "log_level": "info",
  "allowed_user_ids_env": "ALLOWED_USER_IDS"
}
